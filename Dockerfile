FROM atendai/evolution-api:v2.2.3

RUN printf '#!/bin/sh\nset -e\nDB="${DATABASE_CONNECTION_URI:-${DATABASE_URL}}"\nENV_PATH=$(find / -name ".env" -not -path "*/proc/*" -not -path "*/sys/*" 2>/dev/null | head -1)\necho "==> .env encontrado en: ${ENV_PATH}"\ncat > "${ENV_PATH}" << ENVEOF\nSERVER_TYPE=http\nSERVER_PORT=8080\nSERVER_URL=${SERVER_URL:-http://localhost:8080}\nDOCKER_ENV=true\nCORS_ORIGIN=*\nCORS_METHODS=GET,POST,PUT,DELETE\nCORS_CREDENTIALS=true\nLOG_LEVEL=ERROR,WARN,DEBUG,INFO,LOG,VERBOSE,DARK,WEBHOOKS\nLOG_COLOR=true\nLOG_BAILEYS=error\nAUTHENTICATION_TYPE=apikey\nAUTHENTICATION_API_KEY=${AUTHENTICATION_API_KEY:-flowdesk2025}\nAUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=false\nDATABASE_ENABLED=true\nDATABASE_PROVIDER=postgresql\nDATABASE_CONNECTION_URI=${DB}\nDATABASE_CONNECTION_CLIENT_NAME=evolution_exchange\nDATABASE_SAVE_DATA_INSTANCE=true\nDATABASE_SAVE_DATA_NEW_MESSAGE=true\nDATABASE_SAVE_MESSAGE_UPDATE=true\nDATABASE_SAVE_DATA_CONTACTS=true\nDATABASE_SAVE_DATA_CHATS=true\nDATABASE_SAVE_DATA_LABELS=true\nDATABASE_SAVE_DATA_HISTORIC=true\nCACHE_REDIS_ENABLED=false\nCACHE_LOCAL_ENABLED=true\nCONFIG_SESSION_PHONE_CLIENT=FlowDesk\nCONFIG_SESSION_PHONE_NAME=Chrome\nLANGUAGE=${LANGUAGE:-es-ES}\nENVEOF\necho "==> .env sobreescrito OK. DB=${DB}"\n\n# Correr migraciones de Prisma\nAPP_DIR=$(dirname "$ENV_PATH")\necho "==> Corriendo migraciones en ${APP_DIR}"\ncd "$APP_DIR"\nnpm run db:push 2>/dev/null || npx prisma db push --schema ./prisma/postgresql-schema.prisma 2>/dev/null || echo "==> Migraciones fallaron, continuando..."\n\nexec "$@"\n' > /entrypoint.sh && chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
CMD ["npm", "run", "start:prod"]
